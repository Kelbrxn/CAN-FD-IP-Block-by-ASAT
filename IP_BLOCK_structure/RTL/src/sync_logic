module sync_logic (
    input  logic       clk,
    input  logic       rst_n,
    
    // Physical CAN Bus
    input  logic       rx_pin,
    
    // From Bit Timing Module
    input  logic       bit_done_en,
    input  logic [7:0] current_seg_count,
    
    // From Register Bank
    input  logic [7:0] nom_sjw,
    input  logic [7:0] data_sjw,
    input  logic [7:0] tseg1,         // Needed for early edge math!
    input  logic [7:0] tseg2,         // Needed for early edge math!
    
    // From Protocol FSM
    input  logic       is_idle,
    input  logic       is_data_phase,
    
    // Outputs to Bit Timing Module
    output logic       sync_restart,
    output logic [7:0] tseg1_modifier,
    output logic [7:0] tseg2_modifier
);

    // --- 1. FSM State Declarations ---
    typedef enum logic [1:0] {
        IDLE       = 2'b00,
        HARD_SYNC  = 2'b01,
        LATE_EDGE  = 2'b10,
        EARLY_EDGE = 2'b11
    } state_t;

    state_t state;

    // --- 2. Internal Signals ---
    logic [2:0] rx_sync;
    logic       edge_detected;
    logic [7:0] active_sjw;
    
    logic [7:0] phase_error_early;
    logic [7:0] total_bit_len;

    // --- 3. Synchronizer & Edge Detector ---
    // Triple-flop to prevent metastability and detect 1->0 drop
    always_ff @(posedge clk or negedge rst_n) begin
        if (!rst_n) 
            rx_sync <= 3'b111;
        else 
            rx_sync <= {rx_sync[1:0], rx_pin};
    end
    assign edge_detected = (rx_sync[2] == 1'b1 && rx_sync[1] == 1'b0);

    // --- 4. Combinational Math Setup ---
    // The Gear Shifter: Choose correct SJW limit based on phase
    assign active_sjw = is_data_phase ? data_sjw : nom_sjw;

    // Pre-calculate Early Edge variables
    assign total_bit_len     = 8'd1 + tseg1 + tseg2;
    assign phase_error_early = total_bit_len - current_seg_count;

    // --- 5. The FSM Core ---
    always_ff @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            state          <= IDLE;
            sync_restart   <= 1'b0;
            tseg1_modifier <= 8'd0;
            tseg2_modifier <= 8'd0;
        end else begin
            // Default pulse behavior
            sync_restart <= 1'b0;

            case (state)
                IDLE: begin
                    // Ensure modifiers are cleared while waiting
                    tseg1_modifier <= 8'd0;
                    tseg2_modifier <= 8'd0;
                    
                    if (edge_detected) begin
                        if (is_idle) begin
                            state <= HARD_SYNC;
                            
                        end else if (current_seg_count > 8'd0 && current_seg_count <= tseg1) begin
                            // LATE EDGE (Before or on Sample Point)
                            state <= LATE_EDGE;
                            // Math: tseg1_modifier = min(current_seg_count, active_sjw)
                            tseg1_modifier <= (current_seg_count < active_sjw) ? current_seg_count : active_sjw;
                            
                        end else if (current_seg_count > tseg1) begin
                            // EARLY EDGE (After Sample Point)
                            state <= EARLY_EDGE;
                            // Math: tseg2_modifier = min(phase_error_early, active_sjw)
                            tseg2_modifier <= (phase_error_early < active_sjw) ? phase_error_early : active_sjw;
                        end
                    end
                end

                HARD_SYNC: begin
                    // Pulse the reset line to the Bit Timing module
                    sync_restart <= 1'b1;
                    state        <= IDLE;
                end

                LATE_EDGE: begin
                    // STATE LOCKOUT: Hold modifier steady and ignore new edges
                    if (bit_done_en) begin
                        tseg1_modifier <= 8'd0;
                        state          <= IDLE;
                    end
                end

                EARLY_EDGE: begin
                    // STATE LOCKOUT: Hold modifier steady and ignore new edges
                    if (bit_done_en) begin
                        tseg2_modifier <= 8'd0;
                        state          <= IDLE;
                    end
                end
                
                default: state <= IDLE;
            endcase
        end
    end

endmodule
