module can_register_bank (
    input  logic clk,
    input  logic rst_n,

    // Native Bus Interface
    input  logic        cs_regs,
    input  logic        bus_wr_e,
    input  logic [7:0]  bus_addr,     
    input  logic [31:0] bus_wr_data,
    output logic [31:0] bus_rd_data,

    // Hardware Interface
    input  logic        can_error,    
    output logic        soft_reset,   
    output logic [31:0] out_mode,     
    output logic [31:0] out_baud,     
    output logic [31:0] out_btr,
    output logic [31:0] out_f_baud,   // FD Data Phase Baud
    output logic [31:0] out_f_btr,    // FD Data Phase BTR
    output logic        tx_trigger    // Pulses when CPU writes to TRR (0x90)
);

    localparam XCAN_SRR_OFFSET    = 8'h00; 
    localparam XCAN_MSR_OFFSET    = 8'h04; 
    localparam XCAN_BRPR_OFFSET   = 8'h08; 
    localparam XCAN_BTR_OFFSET    = 8'h0C; 
    localparam XCAN_SR_OFFSET     = 8'h18; 
    localparam XCAN_F_BRPR_OFFSET = 8'h88; // CAN FD Data Baud
    localparam XCAN_F_BTR_OFFSET  = 8'h8C; // CAN FD Data Timing
    localparam XCAN_TRR_OFFSET    = 8'h90; // TX Ready Request

    logic [31:0] srr_reg, msr_reg, brpr_reg, btr_reg, f_brpr_reg, f_btr_reg;

    always_ff @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            srr_reg    <= 32'h00000001; // Default to Reset State
            msr_reg    <= 32'h0;
            brpr_reg   <= 32'h0; 
            btr_reg    <= 32'h0;
            f_brpr_reg <= 32'h0;
            f_btr_reg  <= 32'h0;
            tx_trigger <= 1'b0;
        end else begin
            tx_trigger <= 1'b0; // Default to 0, pulses high for 1 clock
            if (cs_regs & bus_wr_e) begin
                case (bus_addr)
                    XCAN_SRR_OFFSET:    srr_reg    <= bus_wr_data;
                    XCAN_MSR_OFFSET:    msr_reg    <= bus_wr_data;
                    XCAN_BRPR_OFFSET:   brpr_reg   <= bus_wr_data;
                    XCAN_BTR_OFFSET:    btr_reg    <= bus_wr_data;
                    XCAN_F_BRPR_OFFSET: f_brpr_reg <= bus_wr_data;
                    XCAN_F_BTR_OFFSET:  f_btr_reg  <= bus_wr_data;
                    XCAN_TRR_OFFSET:    tx_trigger <= bus_wr_data[0]; // Trigger!
                endcase
            end
        end
    end

    // Status Register Logic (Mocking the expected driver response)
    // If SRR[0] is 1, we are in CONFIG mode (bit 0 = 1). Otherwise, NORMAL mode (bit 3 = 1).
    logic [31:0] status_reg_wires;
    assign status_reg_wires = srr_reg[0] ? 32'h00000001 : 32'h00000008;

    // Fast Combinational Read Mux
    always_comb begin
        bus_rd_data = 32'h0;
        if (cs_regs) begin
            case (bus_addr)
                XCAN_SRR_OFFSET:    bus_rd_data = srr_reg;
                XCAN_MSR_OFFSET:    bus_rd_data = msr_reg;
                XCAN_BRPR_OFFSET:   bus_rd_data = brpr_reg;
                XCAN_BTR_OFFSET:    bus_rd_data = btr_reg;
                XCAN_SR_OFFSET:     bus_rd_data = status_reg_wires; // Critical for driver!
                XCAN_F_BRPR_OFFSET: bus_rd_data = f_brpr_reg;
                XCAN_F_BTR_OFFSET:  bus_rd_data = f_btr_reg;
            endcase
        end
    end

    // Broadcast to Core
    assign soft_reset = srr_reg[0];
    assign out_mode   = msr_reg;
    assign out_baud   = brpr_reg;
    assign out_btr    = btr_reg;
    assign out_f_baud = f_brpr_reg;
    assign out_f_btr  = f_btr_reg;

endmodule
