module ram_wrapper #(
    parameter DEPTH = 32,
    parameter DATA_WIDTH = 32
)(
    input  logic                         clk,        // Clock signal
    input  logic                         write_en,   // Write enable signal
    input  logic                         read_en,    // Read enable signal
    input  logic [DATA_WIDTH-1:0]        data_in,    // Data input for write operations
    output logic [DATA_WIDTH-1:0]        data_out,   // Data output for read operations
    input  logic [$clog2(DEPTH)-1:0]     write_addr, // Write address
    input  logic [$clog2(DEPTH)-1:0]     read_addr   // Read address
);

    // Internal RAM array
    // Vivado will typically infer "Distributed RAM" (LUTRAM) for small depths (32)
    // and "Block RAM" (BRAM) for larger depths (>= 512).
    logic [DATA_WIDTH-1:0] ram [DEPTH-1:0]; 

    // Synchronous Write Operation
    always_ff @(posedge clk) begin
        if (write_en) begin
            ram[write_addr] <= data_in;
        end
    end

    // Synchronous Read Operation
    // Standard RAMs in Vivado usually have at least one cycle of read latency.
    always_ff @(posedge clk) begin
        if (read_en) begin
            data_out <= ram[read_addr];
        end
    end

endmodule
