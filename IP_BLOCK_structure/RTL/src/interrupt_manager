module interrupt_manager (
    input  logic clk,
    input  logic rst_n,

    // Hardware Events (Pulses from Core)
    input  logic tx_done_pulse,  
    input  logic rx_done_pulse,  
    input  logic error_pulse,    

    // Native Bus Interface
    input  logic        cs_regs,
    input  logic [7:0]  bus_addr, 
    input  logic        bus_wr_e, 
    input  logic [31:0] bus_wr_data,
    output logic [31:0] bus_rd_data,
    
    output logic        irq
);

    localparam XCAN_ISR_OFFSET = 8'h1C; 
    localparam XCAN_IER_OFFSET = 8'h20; 
    localparam XCAN_ICR_OFFSET = 8'h24; 

    // Xilinx Driver Specific Masks
    localparam BIT_TXOK  = 1;
    localparam BIT_RXOK  = 4;
    localparam BIT_ERROR = 8;

    logic [31:0] IER; 
    logic [31:0] ISR; 

    // IER (Interrupt Enable Register)
    always_ff @(posedge clk or negedge rst_n) begin
        if (!rst_n) IER <= 32'h0;
        else if (cs_regs && bus_wr_e && (bus_addr == XCAN_IER_OFFSET))
            IER <= bus_wr_data;
    end

    // ISR (Interrupt Status Register) - Write 1 to Clear
    always_ff @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            ISR <= 32'h0;
        end else begin
            // 1. Clear bits if CPU writes to ICR
            if (cs_regs && bus_wr_e && (bus_addr == XCAN_ICR_OFFSET)) begin
                ISR <= ISR & ~bus_wr_data; 
            end
            
            // 2. Hardware sets bits (Overrides clear if simultaneous)
            if (tx_done_pulse) ISR[BIT_TXOK]  <= 1'b1;
            if (rx_done_pulse) ISR[BIT_RXOK]  <= 1'b1;
            if (error_pulse)   ISR[BIT_ERROR] <= 1'b1;
        end
    end

    // Read Multiplexer
    assign bus_rd_data = 
        (cs_regs && bus_addr == XCAN_ISR_OFFSET) ? ISR :
        (cs_regs && bus_addr == XCAN_IER_OFFSET) ? IER : 32'h0;

    // Trigger CPU IRQ line if any Enabled Status bit is High
    assign irq = |(ISR & IER); 

endmodule
