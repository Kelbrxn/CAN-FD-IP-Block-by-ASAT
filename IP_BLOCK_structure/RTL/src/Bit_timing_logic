module can_bit_timing (
    input  logic        clk,            // 125 MHz System Clock
    input  logic        rst_n,          // Active Low Reset
    
    // Configuration from Register Bank
    input  logic [7:0]  nom_brp,        // Nominal Prescaler
    input  logic [7:0]  data_brp,       // Data Prescaler
    input  logic [7:0]  tseg1,          // Time Segment 1
    input  logic [7:0]  tseg2,          // Time Segment 2
    
    // Control from FSM & Dedicated Sync Module
    input  logic        is_data_phase,  // Switched by Protocol FSM
    input  logic        sync_restart,   // One-cycle pulse from Sync Module to reset counters
    
    // Re-Sync Modifiers from Sync Module
    input  logic [7:0]  tseg1_modifier, // Added to stretch the bit
    input  logic [7:0]  tseg2_modifier, // Subtracted to shrink the bit
    
    // Outputs to Protocol FSM / CRC / Stuffer / Sync Module
    output logic        sample_point_en,
    output logic        bit_done_en,
    output logic [7:0]  current_seg_cnt // So the Sync module knows our current phase
);

    // --- 1. Internal Signals ---
    logic [7:0] tq_cnt;                 // Prescaler counter
    logic [7:0] seg_cnt;                // Segment (TQ) counter
    logic       tq_tick;                // Pulse every Time Quantum
    logic [7:0] active_brp;

    // Expose internal counter for external Sync Module math
    assign current_seg_cnt = seg_cnt;

    // --- 2. The "Gear Shifter" ---
    assign active_brp = is_data_phase ? data_brp : nom_brp;

    // --- 3. Stage 1: The Prescaler (TQ Generator) ---
    always_ff @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            tq_cnt  <= 8'd0;
            tq_tick <= 1'b0;
        end else if (sync_restart) begin
            // Controlled purely by external Sync Module
            tq_cnt  <= 8'd0;
            tq_tick <= 1'b0;
        end else begin
            if (tq_cnt >= active_brp) begin
                tq_cnt  <= 8'd0;
                tq_tick <= 1'b1;
            end else begin
                tq_cnt  <= tq_cnt + 1'b1;
                tq_tick <= 1'b0;
            end
        end
    end

    // --- 4. Stage 2: The Segment Counter ---
    always_ff @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            seg_cnt         <= 8'd0;
            sample_point_en <= 1'b0;
            bit_done_en     <= 1'b0;
        end else if (sync_restart) begin
            // Controlled purely by external Sync Module
            seg_cnt         <= 8'd0;
            sample_point_en <= 1'b0;
            bit_done_en     <= 1'b0;
        end else if (tq_tick) begin
            
            // Generate Sample Point (End of TSEG1 + Stretch)
            if (seg_cnt == (tseg1 + tseg1_modifier)) begin
                sample_point_en <= 1'b1;
            end else begin
                sample_point_en <= 1'b0;
            end

            // Generate Bit Done (End of TSEG2 - Shrink)
            // Total = 1 (Sync) + (TSEG1 + Stretch) + (TSEG2 - Shrink)
            if (seg_cnt >= (tseg1 + tseg1_modifier + tseg2 - tseg2_modifier + 1)) begin
                bit_done_en <= 1'b1;
                seg_cnt     <= 8'd0;
            end else begin
                bit_done_en <= 1'b0;
                seg_cnt     <= seg_cnt + 1'b1;
            end
            
        end else begin
            // Ensure pulses only last one clock cycle
            sample_point_en <= 1'b0;
            bit_done_en     <= 1'b0;
        end
    end

endmodule
